# ---------------------------------------------------------------------------
# Effizienzpioniere Marketing-Automation - Beispiel-Umgebung
# Kopiere diese Datei nach `.env` und fuelle die Werte.
# NIEMALS echte Keys committen. Produktiv kommen die Secrets aus Azure Key Vault.
# ---------------------------------------------------------------------------

# --- Datenquelle fuer das Call-Cockpit ---
# mock  = liest test/mock-deals.json (Phase 0, kein AVV noetig)
# brevo = echte Brevo-REST-API (Phase 1, AVV erforderlich)
DEALS_SOURCE=mock

# --- Brevo (CRM-of-record, Deals-Pipeline) - erst fuer Phase 1 ---
BREVO_API_KEY=
# Optional: abweichender Pipeline-Identifier, falls nicht "Kommunen"
BREVO_PIPELINE_ID=

# --- Identity-Spine ---
# Pepper fuer contact_uid = sha256(lower(email) + PEPPER).
# Produktiv aus Azure Key Vault laden, nicht hier.
CONTACT_UID_PEPPER=dev-only-pepper-change-me

# --- LUMA (Webinar-Funnel) - erst fuer Webinar-Orchestrator (Roadmap 4) ---
LUMA_API_KEY=

# --- PostHog (EU) - erst nach Consent (Roadmap 7) ---
POSTHOG_KEY=

# --- Teams-Delivery ---
# Ziel-Chat/-Channel fuer Daniels Tagesnachricht (M365-MCP). Offener Punkt 12.3.
TEAMS_TARGET=
